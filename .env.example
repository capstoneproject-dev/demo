# Copy these names into your hosting provider's Environment Variables or
# Secrets settings. Do not put a real key in this committed example file.
ANALYTICS_AI_GEMINI_API_KEY=replace_with_a_new_rotated_key
ANALYTICS_AI_GEMINI_MODEL=gemini-2.5-flash
ANALYTICS_AI_GEMINI_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite

# Optional local Ollama fallback. Disable it in production unless the web
# server can actually reach an Ollama instance at this address.
ANALYTICS_AI_LLAMA_BASE_URL=http://127.0.0.1:11434
ANALYTICS_AI_LLAMA_MODEL=llama3.2:3b
